	column PartyMasterName = ```
			
			    IF('INWARD & OUTWARD'[Party City] = BLANK(), "Retail Customer", 'INWARD & OUTWARD'[Party Name])
			```
		lineageTag: 5641e3d3-50ea-42b5-90a0-fbaa09fae041
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column AccountType = ```
			
			    SWITCH(TRUE(),
			        -- Condition for Trade Account
			        'INWARD & OUTWARD'[Transaction Location Id] in {"LA", "SA"} 
			        && 
			        NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name], "LS Retail"), "Trade Account", 
			        -- Condition for Retail Account
			       NOT 'INWARD & OUTWARD'[Transaction Location Id] IN {"LA", "SA", "HP", "LS"}, "Retail Account", 
			        -- Condition for Key Account
			       'INWARD & OUTWARD'[Transaction Location Id] in {"LS"} 
			       && 
			        (
			            (
			            (NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name] , "L.S") && NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name], {"Retail"})) &&
			            (NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name] , "L.S.") && NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name], {"Retail"})) &&
			            (NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name] , "LS") && NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name], {"Retail"})) &&
			            (NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name] , "L S") && NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name], {"Retail"})) && 
			            (NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name] , "L. S.") && NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name], {"Retail"})) &&
			            (NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name] , "L. S") && NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name], {"Retail"})) &&
			            NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name] , "LEO SALES") &&
			            NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name] , "SOHAM SALES") &&
			            NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name] , "RIDHI SIDHI") &&
			            NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name] , "STEPS BHILWARA") &&
			            NOT CONTAINSSTRING('INWARD & OUTWARD'[Party Name] , "KUBER FOOTPRINTS")
			            )
			        )
			       , "Key Account", BLANK())
			
			```
		lineageTag: 75b141c6-2874-4c22-b703-dae5fb9cbf72
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

